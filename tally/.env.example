# Copy to .env and fill in real values.
# Both tally-bridge.js and tally-sync.js read this file.

# --- Supabase (service-role key bypasses RLS — keep private) ---
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- Tally (running on this same Windows machine) ---
TALLY_URL=http://localhost:9003
TALLY_COMPANY=Your Tally Company Name Exactly As It Appears
TALLY_USER=tallyuser
TALLY_PASS=tallypassword

# --- Verification window (Ops Guide §6, §8.8, §8.9) ---
# How many days back/ahead the bridge searches Tally's Day Book.
# 14/14 covers backdated invoices and future-dated ones.
TALLY_LOOKBACK_DAYS=14
TALLY_FORWARD_DAYS=14
