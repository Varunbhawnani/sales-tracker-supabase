# ─── Supabase (mobile app + web) ─────────────────────────────────────
# Copy this file to .env and fill in real values.
# Find them at: Supabase Dashboard → Settings → API
#
# The EXPO_PUBLIC_ prefix tells Expo to bundle these into the JS so the
# client SDK can read them. The anon key is meant to be public — Row-Level
# Security policies in the database are what actually protect your data.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Tally bridge / sync (Windows server only) ──────────────────────
# These are read by tally-sync.js and tally-bridge.js running on the
# Windows server where Tally Prime is installed. The Mac doesn't need
# these set — leave them blank locally if you're only running the app.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

TALLY_URL=http://localhost:9003
TALLY_COMPANY=Your Tally Company Name
TALLY_USER=YourTallyUsername
TALLY_PASS=YourTallyPassword
TALLY_LOOKBACK_DAYS=14
